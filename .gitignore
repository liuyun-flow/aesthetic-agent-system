# ── V2.1.3: Release package exclusions ──

# Environment (real keys)
.env
backend/.env
frontend/.env

# Python
.venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
backend/.pytest_cache/
*.egg-info/

# Node
node_modules/
frontend/node_modules/
frontend/.next/
frontend/out/

# User data — block all files, allow only .gitkeep
backend/data/uploads/*
!backend/data/uploads/.gitkeep
backend/data/database/*.db
!backend/data/database/.gitkeep
backend/data/config/*
!backend/data/config/.gitkeep

# Legacy root-level data paths (safety)
data/uploads/
data/database/*.db
data/config/*
!data/.gitkeep
!data/config/.gitkeep

# Database files
*.db
*.sqlite3

# Backup / export
*.zip

# Build artifacts
dist/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
