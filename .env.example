DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_DEFAULT_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro
DATABASE_URL=sqlite:///./data/database/aesthetic.db
UPLOAD_DIR=./data/uploads
VISION_PROVIDER=placeholder
# Optional request timeout (seconds) for DeepSeek calls. Default 120.
DEEPSEEK_TIMEOUT_SECONDS=120
# V2.4 (optional, experimental): score images directly with a multimodal model
# (needs an OpenAI vision key). Off by default; set to 1/true to enable.
SCORING_VISION_DIRECT=0